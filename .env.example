# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/tayyibt
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=tayyibt

# API Configuration
API_PORT=3000
API_HOST=localhost
NODE_ENV=development

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# Required: docker-compose starts redis with --requirepass ${REDIS_PASSWORD}
# and the ai-service builds its REDIS_URL from it. Must be set.
REDIS_PASSWORD=your_redis_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Frontend URL — where OAuth redirects the browser back to after login.
# Dev: the web app (http://localhost:3002). Prod (same origin behind nginx):
# leave blank for a relative redirect, or set it to your domain.
FRONTEND_URL=http://localhost:3002

# Google OAuth (Sign in with Google)
# Create credentials at https://console.cloud.google.com/apis/credentials
#   - OAuth 2.0 Client ID, type "Web application"
#   - Authorized redirect URI must EXACTLY match GOOGLE_REDIRECT_URI below
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/google

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/github

# AI Service Configuration
AI_SERVICE_URL=http://localhost:5000
AI_MODEL_PATH=./models/

# Email Configuration
EMAIL_SERVICE=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password

# Secrets and Keys
API_KEY=your_api_key_here
SECRET_KEY=your_secret_key_here

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:admin@tayyibt.com

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# Environment
ENVIRONMENT=development

# MCP Server Configuration
FIGMA_API_KEY=your_figma_personal_access_token_here
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_personal_access_token_here
BRAVE_API_KEY=your_brave_search_api_key_here
