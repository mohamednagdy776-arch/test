# Production environment variables
# Copy to .env.production and fill in real values — NEVER commit .env.production

# Database
DATABASE_URL=postgresql://user:strongpassword@postgres:5432/tayyibt
DB_USER=user
DB_PASSWORD=strongpassword
DB_NAME=tayyibt

# Redis (with password in production)
REDIS_URL=redis://:redispassword@redis:6379
REDIS_PASSWORD=redispassword

# JWT — use a long random secret in production
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m

# API
API_PORT=3000
NODE_ENV=production

# CORS — comma-separated list of allowed origins (e.g. your domain and IP)
CORS_ORIGIN=https://yourdomain.com,https://145-14-158-100.sslip.io

# Frontend URL — where OAuth redirects the browser after login. Web app and API
# share this origin behind nginx, so /dashboard resolves to the web app.
FRONTEND_URL=https://145-14-158-100.sslip.io

# Google OAuth (Sign in with Google)
# Client ID and redirect URI are not secrets; the secret IS — keep it out of git.
# The redirect URI must EXACTLY match the one registered in Google Cloud Console.
GOOGLE_CLIENT_ID=547138867997-1if96lhap7nu18oned09rejod7oq7i9a.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://145-14-158-100.sslip.io/api/v1/auth/oauth/google

# Admin dashboard
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1

# Web app WebSocket
NEXT_PUBLIC_WS_URL=https://yourdomain.com

# AI Service
AI_SERVICE_URL=http://ai-service:5000

# Scoring weights (optional — defaults used if not set)
WEIGHT_RELIGIOUS=0.30
WEIGHT_LIFESTYLE=0.25
WEIGHT_INTERESTS=0.20
WEIGHT_LOCATION=0.15
WEIGHT_OTHER=0.10
