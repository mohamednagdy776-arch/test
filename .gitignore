nul

# Per-service .dockerignore files are unused — every service builds with the
# repo root as context, so Docker only reads the root .dockerignore (tracked).
/admin/.dockerignore
/ai-service/.dockerignore
/backend/.dockerignore
/web/.dockerignore

# Database
*.sqlite
*.sqlite3
*.db

# Model files (trained ML artifacts). Scoped to ai-service only -- a bare
# `models/` previously matched ANY directory named `models` repo-wide,
# including every Flutter feature's `data/models/` (a standard
# clean-architecture folder name, see mobile/.claude/skills/mobile-flutter),
# silently dropping those files from every commit with no warning. NOTE: this
# must not swallow the ai-service Python package `app/models/` — without it
# the service crashes with `ModuleNotFoundError: No module named 'app.models'`
# once only tracked files ship (git archive). Re-include that source package
# explicitly.
ai-service/**/models/
!ai-service/app/models/
!ai-service/app/models/**
*.h5
*.pkl
*.joblib

# Deploy build artifact
app.tar.gz
.gstack/
token2.json
token*.json

# Panda CSS generated output (regenerated by `panda codegen && panda cssgen`)
web/styled-system/
