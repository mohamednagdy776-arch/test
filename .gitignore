# Dependencies
node_modules/
__pycache__/
*.pyc
*.egg-info/
.venv/
venv/
env/

# Environment variables
.env
.env.local
.env.*.local
.env.production
.env.staging

# Secrets / credentials / SSL — never commit
certs/
*.pem
*.key
cookies.txt
token*.json
secrets/

# Build outputs
dist/
build/
*.o
*.so
*.dylib
*.tsbuildinfo
.next/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
.cache/

# OS
Thumbs.db
.DS_Store
nul

# Per-service .dockerignore files are unused — every service builds with the
# repo root as context, so Docker only reads the root .dockerignore (tracked).
/admin/.dockerignore
/ai-service/.dockerignore
/backend/.dockerignore
/web/.dockerignore

# Database
*.sqlite
*.sqlite3
*.db

# Model files (trained ML artifacts). NOTE: this must not swallow the
# ai-service Python package `app/models/` — without it the service crashes with
# `ModuleNotFoundError: No module named 'app.models'` once only tracked files
# ship (git archive). Re-include that source package explicitly.
models/
!ai-service/app/models/
!ai-service/app/models/**
*.h5
*.pkl
*.joblib

# Deploy build artifact
app.tar.gz
.gstack/
token2.json
token*.json

# Panda CSS generated output (regenerated by `panda codegen && panda cssgen`)
web/styled-system/
