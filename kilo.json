{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "anthropic/claude-sonnet-4-20250514",
  "small_model": "anthropic/claude-haiku-3-20240307",
  "default_agent": "orchestrator",
  "instructions": [
    "AGENTS.md"
  ],
  "plugin": [
    "file:./.kilo"
  ],
  "autoupdate": "notify",
  "snapshot": true,
  "provider": {
    "anthropic": {
      "options": {
        "apiKey": "$ANTHROPIC_API_KEY"
      }
    }
  },
  "permission": {
    "bash": "allow",
    "edit": {
      "src/**": "allow",
      ".kilo/**": "allow",
      ".github/**": "allow",
      "deployment/**": "allow",
      "docs/**": "allow",
      "*.lock": "deny",
      "*": "ask"
    },
    "read": "allow",
    "skill": "allow",
    "external_directory": "deny"
  },
  "mcp": {},
  "skills": {
    "paths": [
      "./.kilo/skills"
    ],
    "urls": [
      "https://raw.githubusercontent.com/obra/superpowers/main/skills/"
    ]
  }
}